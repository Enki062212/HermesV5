# Production Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (if you have one)
VITE_BACKEND_URL=https://api.yourdomain.com

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_BROADCAST=true

# App Configuration
VITE_APP_NAME="Hermes + Exponify"
VITE_APP_VERSION=1.0.0

# Privacy/Legal URLs
VITE_PRIVACY_URL=https://www.iubenda.com/privacy-policy/83524104
VITE_COOKIE_URL=https://www.iubenda.com/privacy-policy/83524104/cookie-policy
